# vim:syntax=apparmor

  include <abstractions/desktop-app>
  include <abstractions/fonts>
  include <abstractions/gio-open>
  include <abstractions/openssl>
  include <abstractions/user-tmp>

  userns,

  capability setgid,
  capability setuid,
  capability sys_chroot,
  capability sys_ptrace,

  network inet dgram,
  network inet stream,
  network inet6 dgram,
  network inet6 stream,
  network netlink dgram,
  network netlink raw,

  /etc/machine-id r,
  /sys/devices/system/cpu/present r,
  /usr/bin/xdg-open px,

  /dev/shm/ r,
  owner /dev/shm/** rwlk,
  owner @{PROC}/*/cmdline r,
  owner @{PROC}/*/comm rw,
  owner @{PROC}/*/gid_map w,
  owner @{PROC}/*/mountinfo r,
  owner @{PROC}/*/mounts r,
  owner @{PROC}/*/oom_score_adj w,
  owner @{PROC}/*/setgroups w,
  owner @{PROC}/*/stat r,
  owner @{PROC}/*/statm r,
  owner @{PROC}/*/status r,
  owner @{PROC}/*/task/ r,
  owner @{PROC}/*/task/** r,
  owner @{PROC}/*/uid_map w,
  owner @{run}/user/*/* rwlk,
