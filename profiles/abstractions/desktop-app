# vim:syntax=apparmor

  abi <abi/3.0>,
  

  include <abstractions/audio>
  include <abstractions/base>
  include <abstractions/dconf>
  include <abstractions/dri-enumerate>
  include <abstractions/enchant>
  include <abstractions/freedesktop.org>
  include <abstractions/kde-open5>
  include <abstractions/kde>
  include <abstractions/xdg-desktop>
  include <abstractions/xdg-open>
  include <abstractions/mesa>
  include <abstractions/nameservice>
  include <abstractions/opencl-pocl>
  include <abstractions/qt6>
  include <abstractions/vulkan>
  include <abstractions/wayland>
  include <abstractions/nvidia>

  /etc/timezone r,

  #For KDE apps
  owner @{HOME}/.config/kcminputrc r,
  owner @{HOME}/.config/kdedefaults/kcminputrc r,
  owner @{HOME}/.config/breezerc r,
  owner @{HOME}/.config/kdeglobals r,
  owner @{HOME}/.config/kwinrc r,
  owner @{HOME}/.config/plasmarc r,

  # Common desktop caches
  owner @{HOME}/.cache/icon-cache.kcache rw,
  owner @{HOME}/.cache/mesa_shader_cache/** rwk,
  owner @{HOME}/.cache/mesa_shader_cache_db/** rwk,
  owner @{HOME}/.cache/qtshadercache-*/** rwk,

  # Common toolkit and XDG settings
  owner @{HOME}/.config/fontconfig/fonts.conf r,
  owner @{HOME}/.config/gtk-3.0/** r,
  owner @{HOME}/.config/user-dirs.dirs r,

  # Common icon and MIME caches
  owner @{HOME}/.local/share/icons/hicolor/icon-theme.cache r,
  owner @{HOME}/.local/share/mime/generic-icons r,
  owner @{HOME}/.local/share/mime/mime.cache r,
  owner @{HOME}/.local/share/mime/packages/ r,

  # Common per-user desktop runtime files
  owner @{run}/user/*/dconf/user rw,
  owner @{run}/user/*/pulse/ rw,

  @{PROC}/@{pid}/cmdline r,
  @{sys}/devices/system/cpu/cpu[0-9]*/* r,
